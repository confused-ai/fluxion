{
  "name": "@confused-ai/core",
  "version": "0.1.0",
  "description": "Core agent runner: createAgent(), agent(), and the ReAct loop. Only runtime dependency is zod.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./agent": {
      "types": "./src/agent.ts",
      "default": "./src/agent.ts"
    },
    "./runner": {
      "types": "./src/runner/index.ts",
      "default": "./src/runner/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./agent": {
        "types": "./dist/agent.d.ts",
        "import": "./dist/agent.js",
        "require": "./dist/agent.cjs"
      },
      "./runner": {
        "types": "./dist/runner.d.ts",
        "import": "./dist/runner.js",
        "require": "./dist/runner.cjs"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "require": "./dist/types.cjs"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js",
        "require": "./dist/errors.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@confused-ai/contracts": "workspace:*",
    "zod": ">=3.22.0"
  },
  "peerDependencies": {
    "@confused-ai/db":      "workspace:*",
    "@confused-ai/guard":   "workspace:*",
    "@confused-ai/observe": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@confused-ai/db":      { "optional": true },
    "@confused-ai/guard":   { "optional": true },
    "@confused-ai/observe": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
