{
  "name": "@confused-ai/knowledge",
  "version": "0.1.0",
  "description": "RAG engine, document loaders, and vector store adapters for confused-ai. All vector SDKs are optional peer deps.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".":         { "types": "./src/index.ts",          "default": "./src/index.ts" },
    "./loaders": { "types": "./src/loaders.ts",        "default": "./src/loaders.ts" },
    "./engine":  { "types": "./src/knowledge-engine.ts", "default": "./src/knowledge-engine.ts" }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".":         { "types": "./dist/index.d.ts",              "import": "./dist/index.js",             "require": "./dist/index.cjs" },
      "./loaders": { "types": "./dist/loaders.d.ts",            "import": "./dist/loaders.js",           "require": "./dist/loaders.cjs" },
      "./engine":  { "types": "./dist/knowledge-engine.d.ts",   "import": "./dist/knowledge-engine.js", "require": "./dist/knowledge-engine.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit", "test": "vitest run" },
  "dependencies": { "@confused-ai/contracts": "workspace:*", "@confused-ai/core": "workspace:*" },
  "peerDependencies": { "openai": ">=4.0.0", "@confused-ai/db": "workspace:*" },
  "peerDependenciesMeta": { "openai": { "optional": true }, "@confused-ai/db": { "optional": true } },
  "devDependencies": { "tsup": "^8.4.0", "typescript": "^5.9.3", "vitest": "^4.0.18" },
  "license": "MIT"
}
